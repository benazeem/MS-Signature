generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id                 String   @id @default(cuid())
  userEmail          String
  customerName       String
  items              Json
  total              Int
  status             String   @default("confirmed")
  shippingAddress    Json
  razorpayOrderId    String?
  razorpayPaymentId  String?
  trackingNumber     String?
  carrier            String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userEmail])
  @@index([razorpayOrderId])
  @@map("orders")
}

model Cart {
  id        String   @id @default(cuid())
  userEmail String   @unique
  items     Json     @default("[]")
  updatedAt DateTime @updatedAt

  @@map("carts")
}

model ShippingAddress {
  id        String   @id @default(cuid())
  userEmail String
  name      String
  phone     String
  address   String
  city      String
  state     String
  pincode   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userEmail])
  @@map("shipping_addresses")
}



model Review {
  id        String   @id @default(cuid())
  productId String
  userEmail String
  userName  String
  rating    Int
  comment   String   @db.Text
  images    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([userEmail])
  @@map("reviews")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@map("contact_submissions")
}
