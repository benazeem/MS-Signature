# ==============================
# MS Signature Scents — Full Env Config
# ==============================

# Supabase (PostgreSQL via Prisma)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Supabase Auth (replaces Better Auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Email — Development (Mailtrap.io SMTP)
# Get from: https://mailtrap.io → Inboxes → SMTP Settings
NODEMAILER_HOST=sandbox.smtp.mailtrap.io
NODEMAILER_PORT=2525
NODEMAILER_USER=your-mailtrap-username
NODEMAILER_PASS=your-mailtrap-password
EMAIL_FROM="MS Signature Scents <noreply@mssignaturescents.com>"
NODE_ENV=development

# Email — Production (Brevo SMTP)
# NODEMAILER_HOST=smtp.brevo.com
# NODEMAILER_PORT=587
# NODEMAILER_USER=your-brevo-login@email.com
# NODEMAILER_PASS=your-brevo-smtp-key

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-sanity-api-token

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
